{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "poke-obsidian-gateway",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-08",
	"durable_objects": {
		"bindings": [
			{
				"name": "OBSIDIAN_SESSION",
				"class_name": "ObsidianSession"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["ObsidianSession"]
		}
	]
}
