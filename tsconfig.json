{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "CommonJS",
		"target": "ES2018",
		"noImplicitAny": true,
		"moduleResolution": "node",
		"strictNullChecks": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"lib": [
			"DOM",
			"ES2020"
		]
	},
	"include": [
		"main.ts"
	]
}
